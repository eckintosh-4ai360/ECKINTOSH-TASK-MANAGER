datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client-js"
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
    id        String   @id @default(cuid())
    email     String   @unique
    name      String?
    password  String?
    avatar    String?
    role      UserRole @default(USER)
    title     String?  // e.g. "Senior Backend Engineer"
    timezone  String?  @default("UTC")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    projects         Project[]
    projectMembers   ProjectMember[]
    tasks            Task[]
    teamMembers      TeamMember[]
    notifications    Notification[]
    timeEntries      TimeEntry[]
    sentMessages     Message[]       @relation("MessageSender")
    receivedMessages Message[]       @relation("MessageReceiver")
    sentEmails       InternalEmail[] @relation("EmailFrom")
    receivedEmails   InternalEmail[] @relation("EmailTo")
    standups         Standup[]
    deployments      Deployment[]    @relation("DeployedBy")

    @@map("users")
}

enum UserRole {
    ADMIN
    USER
    GUEST
}

// ─── Project ─────────────────────────────────────────────────────────────────

model Project {
    id          String    @id @default(cuid())
    name        String
    description String?
    status      String    @default("active") // active | paused | completed | archived
    priority    String    @default("medium")  // low | medium | high | critical
    color       String    @default("#00d4ff") // accent color per project
    tech        String[]  // e.g. ["Next.js", "Prisma", "Postgres"]
    startDate   DateTime?
    endDate     DateTime?
    progress    Int       @default(0)
    owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    ownerId     String
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    tasks       Task[]
    members     ProjectMember[]
    analytics   Analytics?
    sprints     Sprint[]
    standups    Standup[]
    repository  Repository?
    deployments Deployment[]

    @@map("projects")
}

// ─── Project Members ─────────────────────────────────────────────────────────

model ProjectMember {
    id        String   @id @default(cuid())
    project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectId String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String
    role      String   @default("member") // lead | backend | frontend | design | devops | member
    joinedAt  DateTime @default(now())

    @@unique([projectId, userId])
    @@map("project_members")
}

// ─── Task ────────────────────────────────────────────────────────────────────

model Task {
    id          String     @id @default(cuid())
    title       String
    description String?
    status      TaskStatus @default(TODO)
    priority    String     @default("medium")
    dueDate     DateTime?
    estimate    Int?       // estimated hours
    project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectId   String
    sprint      Sprint?    @relation(fields: [sprintId], references: [id], onDelete: SetNull)
    sprintId    String?
    assignee    User?      @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
    assigneeId  String?
    tags        String[]   // e.g. ["bug", "feature", "frontend"]
    createdAt   DateTime   @default(now())
    updatedAt   DateTime   @updatedAt

    subtasks    Subtask[]
    reminders   Reminder[]
    timeEntries TimeEntry[]

    @@map("tasks")
}

enum TaskStatus {
    BACKLOG
    TODO
    IN_PROGRESS
    IN_REVIEW
    COMPLETED
    ARCHIVED
}

// ─── Subtask ─────────────────────────────────────────────────────────────────

model Subtask {
    id        String   @id @default(cuid())
    title     String
    completed Boolean  @default(false)
    task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
    taskId    String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("subtasks")
}

// ─── Sprint ──────────────────────────────────────────────────────────────────

model Sprint {
    id        String       @id @default(cuid())
    name      String       // e.g. "Sprint 12 – Auth Module"
    goal      String?
    project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectId String
    status    SprintStatus @default(PLANNING)
    startDate DateTime?
    endDate   DateTime?
    createdAt DateTime     @default(now())
    updatedAt DateTime     @updatedAt

    tasks Task[]

    @@map("sprints")
}

enum SprintStatus {
    PLANNING
    ACTIVE
    COMPLETED
    CANCELLED
}

// ─── Standup ─────────────────────────────────────────────────────────────────

model Standup {
    id           String   @id @default(cuid())
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId       String
    project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
    projectId    String?
    didYesterday String
    doingToday   String
    blockers     String?
    mood         Int      @default(3) // 1–5 emoji mood score
    date         DateTime @default(now())
    createdAt    DateTime @default(now())

    @@map("standups")
}

// ─── Repository ──────────────────────────────────────────────────────────────

model Repository {
    id             String   @id @default(cuid())
    name           String
    url            String
    provider       String   @default("github") // github | gitlab | bitbucket
    defaultBranch  String   @default("main")
    project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectId      String   @unique
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    @@map("repositories")
}

// ─── Deployment ──────────────────────────────────────────────────────────────

model Deployment {
    id          String   @id @default(cuid())
    version     String   // e.g. "v1.2.3"
    environment String   @default("staging") // development | staging | production
    status      String   @default("pending")  // pending | running | success | failed | rolled_back
    project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectId   String
    deployedBy  User     @relation("DeployedBy", fields: [deployedById], references: [id], onDelete: Cascade)
    deployedById String
    deployedAt  DateTime @default(now())
    notes       String?
    duration    Int?     // seconds

    @@map("deployments")
}

// ─── Team ────────────────────────────────────────────────────────────────────

model Team {
    id          String   @id @default(cuid())
    name        String
    description String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    members TeamMember[]

    @@map("teams")
}

model TeamMember {
    id     String @id @default(cuid())
    team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
    teamId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId String
    role   String @default("member")

    @@unique([teamId, userId])
    @@map("team_members")
}

// ─── Calendar ────────────────────────────────────────────────────────────────

model CalendarEvent {
    id          String   @id @default(cuid())
    title       String
    description String?
    startTime   DateTime
    endTime     DateTime
    allDay      Boolean  @default(false)
    type        String   @default("task") // task | meeting | deadline | sprint | release
    color       String?
    projectId   String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@map("calendar_events")
}

// ─── Time Tracking ───────────────────────────────────────────────────────────

model TimeEntry {
    id        String   @id @default(cuid())
    task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
    taskId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String
    duration  Int      // minutes
    notes     String?
    startTime DateTime
    endTime   DateTime
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("time_entries")
}

// ─── Reminder ────────────────────────────────────────────────────────────────

model Reminder {
    id        String   @id @default(cuid())
    task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
    taskId    String
    message   String
    dueTime   DateTime
    sent      Boolean  @default(false)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("reminders")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
    id        String   @id @default(cuid())
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String
    title     String
    message   String
    type      String   @default("info") // info | success | warning | error | deploy | sprint
    read      Boolean  @default(false)
    link      String?  // optional deep-link
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("notifications")
}

// ─── Analytics ───────────────────────────────────────────────────────────────

model Analytics {
    id             String   @id @default(cuid())
    project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectId      String   @unique
    tasksCompleted Int      @default(0)
    tasksTotal     Int      @default(0)
    timeSpent      Int      @default(0) // minutes
    teamSize       Int      @default(0)
    velocity       Float    @default(0) // avg tasks/sprint
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    @@map("analytics")
}

// ─── Messaging ───────────────────────────────────────────────────────────────

model Message {
    id         String   @id @default(cuid())
    content    String?
    senderId   String
    receiverId String
    read       Boolean  @default(false)
    edited     Boolean  @default(false)
    replyToId  String?
    mediaUrl   String?
    mediaType  String?  // image | video | audio | document
    mediaName  String?
    mediaSize  Int?
    createdAt  DateTime @default(now())

    sender   User      @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
    receiver User      @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
    replyTo  Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
    replies  Message[] @relation("MessageReplies")

    @@map("messages")
}

// ─── Internal Email ──────────────────────────────────────────────────────────

model InternalEmail {
    id        String   @id @default(cuid())
    subject   String
    body      String
    fromId    String
    toId      String
    read      Boolean  @default(false)
    createdAt DateTime @default(now())

    from User @relation("EmailFrom", fields: [fromId], references: [id], onDelete: Cascade)
    to   User @relation("EmailTo", fields: [toId], references: [id], onDelete: Cascade)

    @@map("internal_emails")
}
